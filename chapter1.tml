</a>

</div>

<p>

© 2026 Bradley Hobbs

</p>

</footer>

<script>

const section=
document.getElementById(
"fade"
);

const observer=
new IntersectionObserver(
entries=>{

entries.forEach(
entry=>{

if(
entry.isIntersecting
){

entry.target.classList.add(
"show"
);

}

});

});

observer.observe(
section
);

</script>

</body>
</html>
